# Database (auto-filled by Railway Postgres plugin)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Session
SESSION_SECRET=replace-with-a-long-random-string

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
CALLBACK_URL=https://your-app.railway.app/api/auth/callback

# Optional APIs
GIPHY_API_KEY=your-giphy-key
YOUTUBE_API_KEY=your-youtube-key

# ElevenLabs (AI Tutor "Eva" voice) — optional
# If unset, only the browser-voice personas (Female "Afi K" / Male "Dude") work
# and tapping Eva will show a "voice unavailable" toast.
# Get free keys at https://elevenlabs.io/app/settings/api-keys (10k chars/mo each).
# Comma-separated list to multiply the free quota — keys are rotated round-robin.
ELEVENLABS_API_KEYS=sk_yourFirstKey...,sk_yourSecondKey...
# Optional voice overrides (default: Rachel for Eva, Adam for Male)
# ELEVENLABS_EVA_VOICE_ID=21m00Tcm4TlvDq8ikWAM
# ELEVENLABS_MODEL_ID=eleven_turbo_v2_5

# Environment
NODE_ENV=production
