# Database (auto-filled by Railway Postgres plugin)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Session
SESSION_SECRET=replace-with-a-long-random-string

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
CALLBACK_URL=https://your-app.railway.app/api/auth/callback

# Optional APIs
GIPHY_API_KEY=your-giphy-key
YOUTUBE_API_KEY=your-youtube-key

# Sesame CSM (AI Tutor voice) — optional
# If unset, the AI Tutor falls back to the browser's built-in voice.
# See csm-server/README.md for how to deploy the GPU-side CSM server.
SESAME_CSM_URL=https://your-csm-host.example.com
SESAME_CSM_TOKEN=your-shared-bearer-token
SESAME_CSM_TIMEOUT_MS=25000

# Environment
NODE_ENV=production
